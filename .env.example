# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4o-mini

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Buffer ---
BUFFER_DEBOUNCE_SECONDS=8
BUFFER_MAX_MESSAGES=20
BUFFER_KEY_TTL_SECONDS=3600

# --- WhatsApp provider ---
WHATSAPP_PROVIDER=zapi

# --- Z-API ---
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# --- Logging ---
LOG_LEVEL=INFO
LOG_PRETTY=false

# --- Webhook idempotency ---
WEBHOOK_DEDUP_TTL_SECONDS=3600
