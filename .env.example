# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_AGENT_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4o-mini

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Buffer ---
BUFFER_DEBOUNCE_SECONDS=8
BUFFER_MAX_MESSAGES=20
BUFFER_KEY_TTL_SECONDS=3600

# --- WhatsApp provider ---
WHATSAPP_PROVIDER=zapi

# --- Z-API ---
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
ZAPI_DELAY_TYPING=3

# --- Logging ---
LOG_LEVEL=INFO
LOG_PRETTY=false

# --- Webhook idempotency ---
WEBHOOK_DEDUP_TTL_SECONDS=3600

# --- Google Sheets (espelho de leads) ---
# Caminho relativo (a partir da raiz do projeto) ou absoluto pro JSON da
# Service Account. Pasta JsonConsole/ deve estar gitignored e com chmod 600.
GOOGLE_SHEETS_CREDENTIALS_PATH=JsonConsole/sheets-service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_WORKSHEET=Leads
GOOGLE_SHEETS_ENABLED=false

# --- Catalogo de imagens (servidas pelo proprio FastAPI atras do tunel) ---
# URL publica base; a tool enviarImagem compoe `${ASSETS_BASE_URL}/images/<filename>`
# a partir do filename passado pelo agente. Imagens vivem em ./assets/images/.
ASSETS_BASE_URL=https://soll.canequeiro.shop/static

# --- Google Calendar / Meet (agendamento de reuniões) ---
# Projeto GCP separado do Sheets, usando OAuth user consent (não Service Account).
# `client.json` = baixado do GCP > Credenciais > OAuth Client (Desktop app).
# `token.json` = gerado no primeiro auth flow (refresh token).
GOOGLE_CALENDAR_OAUTH_CLIENT_PATH=JsonConsole/calendar-oauth-client.json
GOOGLE_CALENDAR_OAUTH_TOKEN_PATH=JsonConsole/calendar-oauth-token.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_ENABLED=false
